# Anthropic
ANTHROPIC_API_KEY=

# Pipedrive
PIPEDRIVE_API_TOKEN=
PIPEDRIVE_DOMAIN=your-company.pipedrive.com

# Slack
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
# Required when SLACK_USE_BLOCK_KIT=true — used to verify Slack interactivity
# callback signatures on POST /slack/interact.
SLACK_SIGNING_SECRET=
# Flip to true once the Slack app's Interactivity request URL is pointing at
# https://<PUBLIC_BASE_URL>/slack/interact. Disables legacy emoji/Zapier text.
SLACK_USE_BLOCK_KIT=false
# Public base URL for this service (used only for documentation/logging).
PUBLIC_BASE_URL=

# Optional: webhook secret for /webhook/pipedrive
# WEBHOOK_SECRET=

# ── Batch Pipeline (optional — existing webhook flow works without these) ──

# Supabase (district-prospector-batch project)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Firecrawl
FIRECRAWL_API_KEY=
# FIRECRAWL_SCRAPE_TIMEOUT_MS=120000
# FIRECRAWL_SCRAPE_WAIT_FOR_MS=0
# Browser interact for thin JS / paginated staff directories (higher Firecrawl cost)
FIRECRAWL_INTERACT_ENABLED=true
# FIRECRAWL_INTERACT_MIN_MARKDOWN_CHARS=400
# FIRECRAWL_INTERACT_MAX_PAGES=15
# FIRECRAWL_INTERACT_MAX_SECONDS=120
# FIRECRAWL_INTERACT_CONCURRENCY=2

# Batch settings (optional — defaults shown)
# BATCH_CONCURRENCY=10
# BATCH_MAX_TARGET_PAGES=15
# BATCH_CHARS_PER_PAGE=12000
# Directory-first: larger map for triage → fewer targeted scrapes
# BATCH_MAP_CANDIDATE_LIMIT=50
# BATCH_TRIAGE_MAX_CANDIDATES=45
# BATCH_URL_TRIAGE_MODEL=claude-3-5-haiku-20241022
# BATCH_MAX_SCRAPE_URLS=8
# BATCH_ENRICHMENT_URL_CAP=5
# Queue: in Supabase set districts.status = 'manual' to run before 'pending'
# (manual rows: most recently updated first).

# Google Sheets ID for EOD review export (optional)
# GOOGLE_SHEET_ID=
